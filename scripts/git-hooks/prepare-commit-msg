#!/usr/bin/env bash
# Strip IDE/agent co-author and attribution trailers before the commit is created.
set -euo pipefail
msg_file="${1:?}"
sed -i \
  -e '/^Co-authored-by:.*cursoragent@cursor\.com/d' \
  -e '/^Co-authored-by:.*Cursor/d' \
  -e '/^Made-with:.*Cursor/d' \
  -e '/^Made with \[Cursor\]/d' \
  "${msg_file}"
